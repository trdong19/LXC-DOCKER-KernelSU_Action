# 内核源码地址
KERNEL_SOURCE=https://github.com/LineageOS/android_kernel_xiaomi_msm8998

# 内核源码分支
KERNEL_SOURCE_BRANCH=lineage-20

# 内核编译配置（使用Docker支持配置）
KERNEL_CONFIG=sagit_docker_defconfig

# 内核打包名字，自定义，支持英文数字
KERNEL_ZIP_NAME=sagit_mi6_lxc-docker-kernel
# 是否开启kvm
# 百分之90的用户用不到kvm，false即可
ENABLE_KVM=false

# 是否开启lxc-docker，true即可
ENABLE_LXC_DOCKER=true

# 选择要打包的内核镜像文件
# 低端机填Image.gz-dtb
# 高端机可以选择Image.gz，Image
KERNEL_IMAGE_NAME=Image.gz-dtb

# 使用GCC编译器编译（已移除LLVM配置）
# 对于Linux 4.4内核，GCC编译器更稳定

# 是否需要切换python2，一般不需要，false即可
SWITCH_PYTHON=false

# 是否需要dtbo，一般不需要，false即可
NEED_DTBO=false

# ksu部分，如果不需要ksu，以下内容都不用改
# 如果需要ksu，值改成true，下面的参数main不用改
ENABLE_KERNELSU=false
KERNELSU_TAG=main
