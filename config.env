# ===== 内核源码 =====
KERNEL_SOURCE=https://github.com/LineageOS/android_kernel_xiaomi_msm8998
KERNEL_SOURCE_BRANCH=lineage-20

# ===== 机型配置 =====
# 小米6使用sagit_defconfig
KERNEL_CONFIG=sagit_defconfig

# ===== 输出 =====
KERNEL_ZIP_NAME=sagit_mi6_docker_kernel

# ===== Docker/LXC =====
# 开启后会通过add-lxc-docker-kernel-config.sh添加Docker官方要求的全部内核选项
# 包括：overlayfs、veth、bridge、cgroup v1子系统、iptables/NAT、IPVS、BPF、SELinux等
ENABLE_LXC_DOCKER=true

# ===== 内核镜像 =====
# 小米6非AB分区，输出为Image.gz-dtb
KERNEL_IMAGE_NAME=Image.gz-dtb

# ===== 编译选项 =====
# 使用LLVM/Clang编译（y=启用LLVM完整工具链）
LLVM_CONFIG=y

# ===== KVM（保持关闭，MSM8998不支持）=====
ENABLE_KVM=false

# ===== KernelSU（可选，按需开启）=====
ENABLE_KERNELSU=false
KERNELSU_TAG=main

# ===== 可忽略项（保留兼容，小米6不需要）=====
SWITCH_PYTHON=false
NEED_DTBO=false
